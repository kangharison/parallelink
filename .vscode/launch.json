{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "parallelink: CUDA + C/C++ (cuda-gdb)",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/extern/fio/fio",
            "args": [
                "--ioengine=external:${workspaceFolder}/build/parallelink.so",
                "--name=gpu-randread",
                "--rw=randread",
                "--bs=4k",
                "--size=1G",
                "--runtime=10",
                "--time_based",
                "--gpu_warps=4",
                "--n_queues=2",
                "--nvme_dev=/dev/libnvm0"
            ],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "FIO_EXT_ENG_DIR", "value": "${workspaceFolder}/build" },
                { "name": "LD_LIBRARY_PATH", "value": "${workspaceFolder}/extern/bam/build/lib" }
            ],
            "debuggerPath": "/usr/local/cuda/bin/cuda-gdb",
            "stopAtEntry": false,
            "breakOnLaunch": false
        },
        {
            "name": "parallelink: host only (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/extern/fio/fio",
            "args": [
                "--ioengine=external:${workspaceFolder}/build/parallelink.so",
                "--name=gpu-randread",
                "--rw=randread",
                "--bs=4k",
                "--size=1G",
                "--runtime=10",
                "--time_based",
                "--gpu_warps=4",
                "--n_queues=2",
                "--nvme_dev=/dev/libnvm0"
            ],
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "FIO_EXT_ENG_DIR", "value": "${workspaceFolder}/build" },
                { "name": "LD_LIBRARY_PATH", "value": "${workspaceFolder}/extern/bam/build/lib" }
            ],
            "MIMode": "gdb",
            "stopAtEntry": false,
            "externalConsole": false
        }
    ]
}
