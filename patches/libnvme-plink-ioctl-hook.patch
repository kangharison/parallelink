diff --git a/src/nvme/ioctl.c b/src/nvme/ioctl.c
index a887ae48..1c1bbc06 100644
--- a/src/nvme/ioctl.c
+++ b/src/nvme/ioctl.c
@@ -30,6 +30,18 @@
 #include "util.h"
 #include "log.h"
 
+#ifdef PLINK
+/*
+ * parallelink: redirect admin passthrough ioctls to an out-of-band
+ * Unix-domain socket so an external controller (the parallelink fio
+ * engine) can execute them on this process's behalf. The hook lives
+ * outside the libnvme tree — see src/plink_ioctl_hook.c in the
+ * parallelink repository. Non-admin ioctls pass straight through to
+ * the real ioctl(2) inside the hook.
+ */
+extern int plink_ioctl_hook(int fd, unsigned long ioctl_cmd, void *arg);
+#endif
+
 static int nvme_verify_chr(int fd)
 {
 	static struct stat nvme_stat;
@@ -98,7 +110,11 @@ __attribute__((weak))
 int nvme_submit_passthru(int fd, unsigned long ioctl_cmd,
 			 struct nvme_passthru_cmd *cmd, __u32 *result)
 {
+#ifdef PLINK
+	int err = plink_ioctl_hook(fd, ioctl_cmd, cmd);
+#else
 	int err = ioctl(fd, ioctl_cmd, cmd);
+#endif
 
 	if (err >= 0 && result)
 		*result = cmd->result;
